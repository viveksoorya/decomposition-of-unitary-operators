\addvspace {10\p@ }
\contentsline {figure}{\numberline {C.1}{\ignorespaces CNOT cascade identity $\mathrm {CNOT}_{ij}\,\mathrm {CNOT}_{ji}\,\mathrm {CNOT}_{ij} = \mathrm {SWAP}$. Three alternating CNOT gates swap the states of two qubits. This is optimal: no circuit with fewer than three CNOTs can implement SWAP.\relax }}{56}{figure.caption.24}%
