\@writefile{lof}{\contentsline {figure}{\numberline {3.4}{\ignorespaces Block-ZXZ decomposition of an $n$-qubit unitary $U = D_Z  cdot U_X  cdot D_Z'$. The alternating $Z$--$X$--$Z$ structure is a direct generalisation of the single-qubit Z-Y decomposition. The Hadamard conjugation identity converts $Z$-type blocks to $X$-type blocks at the $D_Z !/U_X$ interface, enabling additional CNOT cancellations not available in the QSD.\relax }}{36}{figure.caption.18}\protected@file@percent }
\newlabel{fig:block-zxz}{{3.4}{36}{Block-ZXZ decomposition of an $n$-qubit unitary $U = D_Z \\cdot U_X \\cdot D_Z'$. The alternating $Z$--$X$--$Z$ structure is a direct generalisation of the single-qubit Z-Y decomposition. The Hadamard conjugation identity converts $Z$-type blocks to $X$-type blocks at the $D_Z\\!/U_X$ interface, enabling additional CNOT cancellations not available in the QSD.\relax }{figure.caption.18}{}}
\newlabel{fig:block-zxz@cref}{{[figure][4][3]3.4}{[1][35][]36}}
