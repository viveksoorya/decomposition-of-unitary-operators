\@writefile{lof}{\contentsline {figure}{\numberline {2.6}{\ignorespaces KAK decomposition of a two-qubit unitary $U \in SU(4)$. The two local unitaries $A_1 \otimes A_2$ and $B_1 \otimes B_2$ require no CNOT gates; the entangling core $e^{iH}$ requires 1--3 CNOT gates depending on its non-local parameters.\relax }}{19}{figure.caption.13}\protected@file@percent }
\newlabel{fig:kak-schematic}{{2.6}{19}{KAK decomposition of a two-qubit unitary $U \in SU(4)$. The two local unitaries $A_1 \otimes A_2$ and $B_1 \otimes B_2$ require no CNOT gates; the entangling core $e^{iH}$ requires 1--3 CNOT gates depending on its non-local parameters.\relax }{figure.caption.13}{}}
